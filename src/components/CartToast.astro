---
---
<!-- Slide-up "added to cart" confirmation bar -->
<div id="cart-toast" class="cart-toast" role="status" aria-live="polite">
  <div class="cart-toast-inner">
    <span class="cart-toast-msg">
      <svg class="cart-toast-check" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="11" fill="#0F8095" />
        <path d="M7 12.5l3.2 3.2L17 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>Added to cart</span>
    </span>
    <div class="cart-toast-actions">
      <button type="button" id="cart-toast-view" class="cart-toast-view">View cart</button>
      <button type="button" id="cart-toast-checkout" class="cart-toast-checkout">Checkout</button>
    </div>
    <button type="button" id="cart-toast-close" class="cart-toast-close" aria-label="Dismiss">×</button>
  </div>
</div>
