---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Checkout - Dende Arts" noindex={true}>
  <div class="checkout-loading">
    Redirecting to checkout...
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    if (!window.swell) {
      console.error('Swell not initialized');
      return;
    }
    try {
      // Tag the cart with the GA client id so the server-side purchase event
      // attributes to this session. Best-effort; never blocks checkout.
      if (typeof window.attachGaClientIdToCart === 'function') {
        await window.attachGaClientIdToCart();
      }
      await swell.cart.redirect({
        success_url: window.location.origin + '/thank-you',
      });
    } catch (error) {
      console.error('Error redirecting to checkout:', error);
      alert('Error starting checkout. Please try again.');
      window.location.href = '/';
    }
  });
</script>
