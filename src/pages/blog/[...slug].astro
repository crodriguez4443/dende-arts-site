---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.split('/')[0] },
    props: { post },
  }));
}

function getSlug(id: string) { return id.split('/')[0]; }

const { post } = Astro.props;
const { Content, headings: astroHeadings } = await render(post);

const readableDate = post.data.date
  ? new Date(post.data.date).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
const isoDate = post.data.date
  ? new Date(post.data.date).toISOString().split('T')[0]
  : '';

// Build TOC from Astro's headings (only h2/h3)
const tocHeadings = astroHeadings.filter(h => h.depth === 2 || h.depth === 3);
---
<Layout
  title={post.data.title}
  description={post.data.description}
  socialImage={post.data.socialImage}
>
  <div class="main-grid">
    <Nav />
    <div class="blog-post-container blog-post-grid">
      <article class="blog-post">
        <div class="breadcrumb-container">
          <a href="/">Home/</a>
          <a href="/blog/">Blog/</a>
          <span>{post.data.title}</span>
        </div>
        <h1>{post.data.title}</h1>

        {post.data.coverImage && (
          <div class="blog-post-featured-image">
            <Image src={post.data.coverImage} alt={post.data.title} class="blog-featured-image" />
          </div>
        )}

        <div class="blog-post-meta">
          <time datetime={isoDate}>{readableDate}</time>
        </div>

        <div class="blog-post-content">
          <Content />
        </div>
      </article>

      <aside class="blog-post-sidebar">
        {tocHeadings.length > 0 && (
          <>
            <h3>Table of Contents</h3>
            <div class="table-of-contents">
              <nav class="toc-nav">
                <ul>
                  {tocHeadings.map(h => (
                    <li class={`toc-level-${h.depth}`}>
                      <a href={`#${h.slug}`}>{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </>
        )}
      </aside>
    </div>
  </div>
</Layout>
