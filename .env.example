# Shipping integration (Swell → Shippo)
# Set all of these in the Netlify dashboard (Site configuration → Environment
# variables) before going live. See docs/shipping-integration.md.

# Shippo test or live API key (test keys start with shippo_test_)
SHIPPO_API_KEY=
# object_id of your USPS carrier connection inside Shippo
SHIPPO_USPS_CARRIER_ACCOUNT_ID=
# Random string appended to the Shippo webhook URL as ?secret=...
SHIPPO_WEBHOOK_SECRET=

# Random string appended to the Swell webhook URL as ?secret=...
# (Swell doesn't sign webhook bodies — auth is via a shared secret in the URL)
SWELL_WEBHOOK_SECRET=
# Swell store ID (Basic auth username for the admin API)
SWELL_STORE_ID=
# Swell admin API secret key (Basic auth password)
SWELL_SECRET_KEY=

# Resend API key
RESEND_API_KEY=
# Verified sender address (e.g. labels@dendearts.com)
EMAIL_FROM=
# Where labels and alerts are sent (e.g. dende.arts@gmail.com)
EMAIL_TO=
